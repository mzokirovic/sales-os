generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  OWNER
  MANAGER
  SALES
  OPERATOR
  WAREHOUSE
  DELIVERY
}

enum OrderStatus {
  NEW
  CHECKED
  CONFIRMED
  PREPARING
  SHIPPED
  DELIVERED
  PAID
}

enum DeliveryTripStatus {
  PLANNED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum DeliveryStopStatus {
  PENDING
  DELIVERED
  FAILED
}

model Tenant {
  id        String   @id @default(uuid())
  name      String
  createdAt DateTime @default(now())

  users             User[]
  customers         Customer[]
  products          Product[]
  orders            Order[]
  payments          Payment[]
  activities        Activity[]
  deliveryTrips     DeliveryTrip[]
  deliveryTripStops DeliveryTripStop[]
}

model User {
  id       String @id @default(uuid())
  tenantId String

  fullName     String
  phone        String @unique
  passwordHash String

  role Role

  createdAt DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id])

  orders                Order[]
  activities            Activity[]
  createdCustomers      Customer[]     @relation("CustomerCreatedBy")
  deliveryTripsAsDriver DeliveryTrip[] @relation("DeliveryTripDriver")
  deliveryTripsAssigned DeliveryTrip[] @relation("DeliveryTripAssignedBy")

  @@index([tenantId])
  @@index([tenantId, role])
}

model Customer {
  id       String @id @default(uuid())
  tenantId String

  createdById String?

  name    String
  phone   String?
  address String?

  lat Float?
  lng Float?

  note String?

  createdAt DateTime @default(now())

  tenant    Tenant @relation(fields: [tenantId], references: [id])
  createdBy User?  @relation("CustomerCreatedBy", fields: [createdById], references: [id])

  orders Order[]

  @@index([tenantId])
  @@index([tenantId, createdById])
}

model Product {
  id       String @id @default(uuid())
  tenantId String

  name String
  sku  String?
  unit String  @default("dona")

  price    Float
  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant     Tenant      @relation(fields: [tenantId], references: [id])
  orderItems OrderItem[]

  @@unique([tenantId, name])
  @@index([tenantId])
  @@index([tenantId, isActive])
}

model Order {
  id String @id @default(uuid())

  tenantId    String
  customerId  String
  createdById String

  status OrderStatus @default(NEW)

  totalAmount Float @default(0)
  debtAmount  Float @default(0)

  createdAt DateTime @default(now())

  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  customer  Customer @relation(fields: [customerId], references: [id])
  createdBy User     @relation(fields: [createdById], references: [id])

  items         OrderItem[]
  payments      Payment[]
  deliveryStops DeliveryTripStop[]

  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, createdById])
  @@index([tenantId, customerId])
}

model OrderItem {
  id String @id @default(uuid())

  orderId   String
  productId String?

  productName String

  quantity Float
  price    Float
  total    Float

  order   Order    @relation(fields: [orderId], references: [id])
  product Product? @relation(fields: [productId], references: [id])

  @@index([orderId])
  @@index([productId])
}

model Payment {
  id String @id @default(uuid())

  tenantId String
  orderId  String

  amount Float

  paymentMethod String?

  createdAt DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id])
  order  Order  @relation(fields: [orderId], references: [id])

  @@index([tenantId])
  @@index([orderId])
}

model Activity {
  id String @id @default(uuid())

  tenantId String
  userId   String

  action String

  entityType String
  entityId   String

  createdAt DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id])
  user   User   @relation(fields: [userId], references: [id])

  @@index([tenantId])
  @@index([userId])
  @@index([entityType, entityId])
}

model DeliveryTrip {
  id String @id @default(uuid())

  tenantId     String
  driverId     String
  assignedById String

  status DeliveryTripStatus @default(PLANNED)

  startedAt   DateTime?
  completedAt DateTime?
  cancelledAt DateTime?
  createdAt   DateTime  @default(now())

  tenant     Tenant @relation(fields: [tenantId], references: [id])
  driver     User   @relation("DeliveryTripDriver", fields: [driverId], references: [id])
  assignedBy User   @relation("DeliveryTripAssignedBy", fields: [assignedById], references: [id])

  stops DeliveryTripStop[]

  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, driverId])
  @@index([tenantId, assignedById])
}

model DeliveryTripStop {
  id String @id @default(uuid())

  tenantId  String
  tripId    String
  orderId   String
  sortOrder Int

  status DeliveryStopStatus @default(PENDING)

  deliveredAt DateTime?
  createdAt   DateTime  @default(now())

  tenant Tenant       @relation(fields: [tenantId], references: [id])
  trip   DeliveryTrip @relation(fields: [tripId], references: [id])
  order  Order        @relation(fields: [orderId], references: [id])

  @@unique([tripId, orderId])
  @@unique([tripId, sortOrder])
  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, orderId])
  @@index([tripId])
  @@index([orderId])
}
